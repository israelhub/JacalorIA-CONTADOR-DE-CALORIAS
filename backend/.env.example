# Database 
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres

DB_HOST=aws-0-sa-east-1.pooler.supabase.com
DB_PORT=5432
DB_USER=postgres.[PROJECT_REF]
DB_PASSWORD=[PASSWORD]
DB_NAME=postgres
# Nome da tabela TACO/TCO usada no enriquecimento RAG de calorias
# (o serviço também tenta automaticamente tco_4a_edicao e taco_4a_edicao)
TACO_TABLE_NAME=taco_4a_edicao

# JWT
JWT_SECRET=sua-chave-secreta-aqui-troque-em-producao
JWT_EXPIRATION=7d

# App 
PORT=3000
# development | homologation | production
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:8080

# Dashboard beta (página /beta) — token obrigatório no header x-dashboard-token
BETA_DASHBOARD_TOKEN=troque-este-token-interno

# Email (SMTP)
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=seu-email@provedor.com
MAIL_PASSWORD=sua-senha-ou-app-password
MAIL_FROM=Jacaloria <no-reply@jacaloria.com>
